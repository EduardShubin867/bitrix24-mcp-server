{
  "name": "bitrix24-mcp-server",
  "version": "1.0.0",
  "type": "module",
  "description": "Bitrix24 MCP Server for AI Agent Integration",
  "main": "server.js",
  "bin": {
    "bitrix24-mcp": "./build/index.js"
  },
  "scripts": {
    "prebuild": "node -e \"const fs = require('fs'); if (!fs.existsSync('build')) fs.mkdirSync('build', {recursive: true});\"",
    "build": "tsc",
    "build:unix": "tsc && chmod +x build/index.js",
    "dev": "tsc --watch",
    "export:org-structure": "npm run build && node scripts/export-org-structure.mjs",
    "debug:tools": "npm run build && node scripts/list-registered-tools.mjs",
    "smoke:task-tools": "npm run build && node scripts/smoke-task-tools.mjs",
    "start:mcp": "node build/index.js",
    "start:http": "node build/httpServer.js",
    "start": "node server.js",
    "test": "node test/integration.test.js",
    "postinstall": "node -e \"try { require('child_process').execSync('npm run build', {stdio: 'inherit'}); } catch(e) { console.log('Build failed, but continuing...'); }\"",
    "azure:start": "node server.js"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "files": ["build"],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "zod": "^3.22.4",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.10.0",
    "@types/node-fetch": "^2.6.9",
    "typescript": "^5.3.0"
  },
  "keywords": ["mcp", "bitrix24", "crm", "ai", "automation"],
  "author": "Your Name",
  "license": "MIT"
}
