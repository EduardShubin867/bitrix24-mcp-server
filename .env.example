BITRIX24_WEBHOOK_URL=https://your-domain.bitrix24.com/rest/USER_ID/WEBHOOK_CODE/
NODE_ENV=development
LOG_LEVEL=info

# Streamable HTTP transport (npm run start:http / server.js / Docker)
# 47365 is intentionally non-standard - avoids clashing with common defaults (80/3000/8080).
PORT=47365
HOST=0.0.0.0
# Bearer token required in the "Authorization: Bearer <token>" header for /mcp requests.
# Leave unset only for local/trusted testing - required before exposing the server publicly.
MCP_AUTH_TOKEN=
# Comma-separated list of allowed CORS origins, or * for any origin.
MCP_ALLOWED_ORIGINS=*
